<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>mod_bsr_form</name>
    <author>Andrey Uvikov</author>
    <authorEmail>order@bestsite-studio.ru</authorEmail>
    <authorUrl>https://bestsite-tver.ru</authorUrl>
    <creationDate>2026</creationDate>
    <version>2.1.0</version>
    <description>MOD_BSR_FORM_XML_DESCRIPTION</description>
    <files>
        <filename module="mod_bsr_form">mod_bsr_form.php</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>
    <config>
        <fields name="params">
            <fieldset name="basic" label="MOD_BSR_FORM_FIELDSET_BASIC_LABEL">
                <field name="rf_call_id" type="text" label="MOD_BSR_FORM_FIELD_RF_CALL_ID_LABEL" default="123" />
                <field name="form_title" type="text" label="MOD_BSR_FORM_FIELD_FORM_TITLE_LABEL" default="MOD_BSR_FORM_DEFAULT_FORM_TITLE" />
                <field name="autofill_title" type="radio" layout="joomla.form.field.radio.switcher" label="MOD_BSR_FORM_FIELD_AUTOFILL_TITLE_LABEL" default="1">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="btn_text" type="text" label="MOD_BSR_FORM_FIELD_BTN_TEXT_LABEL" default="MOD_BSR_FORM_DEFAULT_BTN_TEXT" />
                <field name="success_msg" type="textarea" label="MOD_BSR_FORM_FIELD_SUCCESS_MSG_LABEL" default="MOD_BSR_FORM_DEFAULT_SUCCESS_MSG" />
                <field name="redirect_url" type="text" label="MOD_BSR_FORM_FIELD_REDIRECT_URL_LABEL" description="MOD_BSR_FORM_FIELD_REDIRECT_URL_DESC" default="" />
                <field name="ym_goal" type="text" label="MOD_BSR_FORM_FIELD_YM_GOAL_LABEL" description="MOD_BSR_FORM_FIELD_YM_GOAL_DESC" default="" />
                <field name="agreement_text" type="editor" filter="raw" buttons="true" hide="pagebreak,readmore" label="MOD_BSR_FORM_FIELD_AGREEMENT_TEXT_LABEL" default="MOD_BSR_FORM_DEFAULT_AGREEMENT_TEXT" />
                
                <field name="form_fields" type="subform" label="MOD_BSR_FORM_FIELD_FORM_FIELDS_LABEL" multiple="true" min="1" layout="joomla.form.field.subform.repeatable-table">
                    <form>
                        <field name="f_type" type="list" label="MOD_BSR_FORM_FIELD_F_TYPE_LABEL" default="text">
                            <option value="text">MOD_BSR_FORM_OPTION_TEXT</option>
                            <option value="tel">MOD_BSR_FORM_OPTION_TEL</option>
                            <option value="email">MOD_BSR_FORM_OPTION_EMAIL</option>
                            <option value="date">MOD_BSR_FORM_OPTION_DATE</option>
                            <option value="textarea">MOD_BSR_FORM_OPTION_TEXTAREA</option>
                        </field>
                        <field name="f_name" type="text" label="MOD_BSR_FORM_FIELD_F_NAME_LABEL" required="true" />
                        <field name="f_placeholder" type="text" label="MOD_BSR_FORM_FIELD_F_PLACEHOLDER_LABEL" />
                        <field name="f_required" type="radio" layout="joomla.form.field.radio.switcher" label="MOD_BSR_FORM_FIELD_F_REQUIRED_LABEL" default="0">
                            <option value="0">JNO</option>
                            <option value="1">JYES</option>
                        </field>
                        <field name="f_error" type="text" label="MOD_BSR_FORM_FIELD_F_ERROR_LABEL" default="MOD_BSR_FORM_DEFAULT_F_ERROR" />
                    </form>
                </field>
            </fieldset>

            <fieldset name="advanced" label="MOD_BSR_FORM_FIELDSET_ADVANCED_LABEL">
                <field name="form_id" type="text" label="MOD_BSR_FORM_FIELD_FORM_ID_LABEL" description="MOD_BSR_FORM_FIELD_FORM_ID_DESC" default="" />
                <field name="form_class" type="text" label="MOD_BSR_FORM_FIELD_FORM_CLASS_LABEL" default="" />
                <field name="btn_class" type="text" label="MOD_BSR_FORM_FIELD_BTN_CLASS_LABEL" default="" />
                <field name="color_btn" type="color" label="MOD_BSR_FORM_FIELD_COLOR_BTN_LABEL" default="" />
                <field name="color_btn_hover" type="color" label="MOD_BSR_FORM_FIELD_COLOR_BTN_HOVER_LABEL" default="" />
                <field name="color_focus" type="color" label="MOD_BSR_FORM_FIELD_COLOR_FOCUS_LABEL" default="" />
            </fieldset>
        </fields>
    </config>
</extension>